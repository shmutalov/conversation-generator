{
  "name": "conversation-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Animated messaging-app conversation videos via Remotion",
  "scripts": {
    "dev": "remotion studio",
    "render": "remotion render",
    "build": "remotion bundle",
    "typecheck": "tsc --noEmit",
    "ui": "vite --config web/vite.config.ts",
    "ui:build": "vite build --config web/vite.config.ts",
    "serve": "node scripts/render-server.mjs"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@remotion/zod-types": "^4.0.0",
    "express": "^4.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.4.0"
  }
}
